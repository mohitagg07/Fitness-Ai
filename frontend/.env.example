# Copy this file to .env in the same folder (frontend/.env) and fill in
# the value below, then restart with: npx expo start --clear
#
# "localhost" only resolves to your dev machine when the app itself is
# running ON that machine — i.e. in a web browser, or in the iOS
# Simulator. It does NOT work:
#   - On a physical phone/tablet (Expo Go or a dev build) — the phone has
#     no idea what "localhost" means on YOUR computer.
#   - On the Android Emulator — "localhost" there points at the emulator
#     itself, not your host machine.
#
# Pick ONE of the following for EXPO_PUBLIC_API_URL:
#
#   Physical device (Expo Go / dev build), same Wi-Fi as your computer:
#     Use your computer's LAN IP address, e.g.:
#       EXPO_PUBLIC_API_URL=http://192.168.1.23:8000/api
#     Find your LAN IP with:
#       macOS/Linux:  ifconfig | grep "inet "
#       Windows:      ipconfig
#
#   Android Emulator:
#     EXPO_PUBLIC_API_URL=http://10.0.2.2:8000/api
#
#   iOS Simulator or web browser:
#     EXPO_PUBLIC_API_URL=http://localhost:8000/api
#
# Make sure the backend is actually running and reachable at that address
# (uvicorn binds to 127.0.0.1 by default, which is NOT reachable from
# another device — run it with --host 0.0.0.0 so your phone can reach it):
#   uvicorn main:app --reload --host 0.0.0.0 --port 8000

EXPO_PUBLIC_API_URL=http://localhost:8000/api
