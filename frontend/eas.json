{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "env": {
          "EXPO_PUBLIC_API_URL": "http://YOUR_LOCAL_IP:8000/api"
        }
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "env": {
          "EXPO_PUBLIC_API_URL": "https://neurofit-ai-backend.onrender.com/api"
        }
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk",
        "env": {
          "EXPO_PUBLIC_API_URL": "https://neurofit-ai-backend.onrender.com/api"
        }
      }
    }
  },
  "submit": {
    "production": {}
  }
}
