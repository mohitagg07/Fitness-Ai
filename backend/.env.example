# Copy this file to .env in the same folder (backend/.env) and fill in
# your real values, then run: uvicorn main:app --reload --host 0.0.0.0

# Supabase — Project Settings -> API in your Supabase dashboard.
# Use the "service_role" key here (NOT the "anon" public key) — the
# backend needs it to bypass RLS for server-side writes.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Groq — https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# Any long random string — used to sign JWTs. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# Optional overrides (defaults shown):
# GROQ_MODEL=llama-3.3-70b-versatile
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:5173

# FatSecret API (for food search / macro auto-fill)
FATSECRET_CLIENT_ID=1d86664cb6fb408cb5c55abbdb509607
FATSECRET_CLIENT_SECRET=f9867e5f52b6408b9027e2b5ff2913bc
